{
  "name": "@community-garden/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":          "nodemon --exec tsx src/index.ts",
    "build":        "tsc",
    "start":        "node dist/index.js",
    "migrate":      "tsx src/db/migrate.ts",
    "seed":         "tsx src/db/seed.ts",
    "test":         "jest",
    "test:watch":   "jest --watch",
    "test:coverage": "jest --coverage",
    "lint":         "eslint src --ext .ts",
    "typecheck":    "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "redis": "^4.6.14",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.3",
    "tsx": "^4.16.2",
    "typescript": "^5.4.0"
  }
}
